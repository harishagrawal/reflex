import pytest
from unittest.mock import patch, MagicMock
from reflex.reflex import export

class Test_ReflexExport:

    @pytest.mark.smoke
    @pytest.mark.valid
    def test_export_with_zip_and_frontend_only(self):
        with patch('reflex.utils.export.export') as mock_export:
            export(
                zip=True,
                frontend_only=True,
                backend_only=False,
                zip_dest_dir='./export',
                upload_db_file=False,
                env=constants.Env.DEV,
            )
            mock_export.assert_called_once_with(
                zipping=True,
                frontend=True,
                backend=False,
                zip_dest_dir='./export',
                upload_db_file=False,
                env=constants.Env.DEV,
                loglevel=constants.LogLevel.DEFAULT,
            )

    @pytest.mark.smoke
    @pytest.mark.valid
    def test_export_with_backend_only(self):
        with patch('reflex.utils.export.export') as mock_export:
            export(
                zip=False,
                frontend_only=False,
                backend_only=True,
                zip_dest_dir='./export',
                upload_db_file=False,
                env=constants.Env.PROD,
            )
            mock_export.assert_called_once_with(
                zipping=False,
                frontend=False,
                backend=True,
                zip_dest_dir='./export',
                upload_db_file=False,
                env=constants.Env.PROD,
                loglevel=constants.LogLevel.DEFAULT,
            )

    @pytest.mark.smoke
    @pytest.mark.valid
    def test_export_with_zip_and_both_frontend_and_backend(self):
        with patch('reflex.utils.export.export') as mock_export:
            export(
                zip=True,
                frontend_only=False,
                backend_only=False,
                zip_dest_dir='./export',
                upload_db_file=False,
                env=constants.Env.DEV,
            )
            mock_export.assert_called_once_with(
                zipping=True,
                frontend=True,
                backend=True,
                zip_dest_dir='./export',
                upload_db_file=False,
                env=constants.Env.DEV,
                loglevel=constants.LogLevel.DEFAULT,
            )

    @pytest.mark.smoke
    @pytest.mark.valid
    def test_export_with_upload_db_file(self):
        with patch('reflex.utils.export.export') as mock_export:
            export(
                zip=False,
                frontend_only=False,
                backend_only=False,
                zip_dest_dir='./export',
                upload_db_file=True,
                env=constants.Env.DEV,
            )
            mock_export.assert_called_once_with(
                zipping=False,
                frontend=True,
                backend=True,
                zip_dest_dir='./export',
                upload_db_file=True,
                env=constants.Env.DEV,
                loglevel=constants.LogLevel.DEFAULT,
            )

    @pytest.mark.smoke
    @pytest.mark.valid
    def test_export_in_production_environment(self):
        with patch('reflex.utils.export.export') as mock_export:
            export(
                zip=False,
                frontend_only=False,
                backend_only=False,
                zip_dest_dir='./export',
                upload_db_file=False,
                env=constants.Env.PROD,
            )
            mock_export.assert_called_once_with(
                zipping=False,
                frontend=True,
                backend=True,
                zip_dest_dir='./export',
                upload_db_file=False,
                env=constants.Env.PROD,
                loglevel=constants.LogLevel.DEFAULT,
            )

    @pytest.mark.smoke
    @pytest.mark.invalid
    def test_export_with_missing_config_file(self):
        with patch('reflex.config.get_config') as mock_get_config:
            mock_get_config.side_effect = FileNotFoundError
            with pytest.raises(FileNotFoundError):
                export(
                    zip=False,
                    frontend_only=False,
                    backend_only=False,
                    zip_dest_dir='./export',
                    upload_db_file=False,
                    env=constants.Env.DEV,
                )

    @pytest.mark.smoke
    @pytest.mark.valid
    def test_export_with_reinitialization_needed(self):
        with patch('reflex.utils.prerequisites.needs_reinit') as mock_needs_reinit:
            mock_needs_reinit.return_value = True
            with patch('reflex.utils.export.export') as mock_export:
                export(
                    zip=False,
                    frontend_only=False,
                    backend_only=False,
                    zip_dest_dir='./export',
                    upload_db_file=False,
                    env=constants.Env.DEV,
                )
                mock_export.assert_called_once_with(
                    zipping=False,
                    frontend=True,
                    backend=True,
                    zip_dest_dir='./export',
                    upload_db_file=False,
                    env=constants.Env.DEV,
                    loglevel=constants.LogLevel.DEFAULT,
                )

    @pytest.mark.smoke
    @pytest.mark.invalid
    def test_export_with_invalid_environment(self):
        with pytest.raises(ValueError):
            export(
                zip=False,
                frontend_only=False,
                backend_only=False,
                zip_dest_dir='./export',
                upload_db_file=False,
                env='invalid_env',
            )
